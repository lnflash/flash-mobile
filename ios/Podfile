ENV['RCT_NEW_ARCH_ENABLED'] = '1'
require_relative '../node_modules/react-native/scripts/react_native_pods'
require_relative '../node_modules/@react-native-community/cli-platform-ios/native_modules'

platform :ios, '15.1'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

$RNFirebaseAnalyticsWithoutAdIdSupport=true

target 'LNFlash' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],

    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
  pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec', :modular_headers => false
  pod 'RNFS', :path => '../node_modules/react-native-fs'
  # Use xcframework variant for arm64 simulator (iOS 26+) support
  pod 'GT3Captcha-iOS-xcframework'

  # Firebase pods with modular headers
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseAppCheck', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseABTesting', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'nanopb', :modular_headers => true

end

target 'LNFlash-Alt' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )
  pod 'glog', :podspec => '../node_modules/react-native/third-party-podspecs/glog.podspec', :modular_headers => false
  pod 'RNFS', :path => '../node_modules/react-native-fs'
  # Use xcframework variant for arm64 simulator (iOS 26+) support
  pod 'GT3Captcha-iOS-xcframework'

  # Firebase pods with modular headers
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseAppCheck', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseABTesting', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'GoogleUtilities', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'nanopb', :modular_headers => true

end


post_install do |installer|
  # React Native 0.76 post_install configuration
  react_native_post_install(
    installer,
    :mac_catalyst_enabled => false
  )

  installer.pods_project.targets.each do |target|
    if target.respond_to?(:product_type) and target.product_type == "com.apple.product-type.bundle"
      target.build_configurations.each do |config|
          config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
      end
    end

    # Fix fmt consteval error with Xcode 26.4+ clang
    if target.name == 'fmt'
      target.build_configurations.each do |config|
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      end
    end

    # Fix deployment target warnings
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
      # Xcode 16: library evolution forces every Swift pod to emit + verify a
      # .swiftinterface, and the verifier can't resolve cross-pod modules
      # (FBLPromises, etc.). An app doesn't need distributable interfaces, so
      # turn it off — this removes the whole swiftinterface failure class.
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
    end
  end


  bitcode_strip_path = `xcrun --find bitcode_strip`.chop!
  def strip_bitcode_from_framework(bitcode_strip_path, framework_relative_path)
    framework_path = File.join(Dir.pwd, framework_relative_path)
    command = "#{bitcode_strip_path} #{framework_path} -r -o #{framework_path}"
    puts "Stripping bitcode: #{command}"
    system(command)
  end

  framework_paths = [
    "Pods/LogRocket/LogRocket.xcframework/ios-arm64/LogRocket.framework/LogRocket",
    "Pods/hermes-engine/destroot/Library/Frameworks/macosx/hermes.framework/hermes",
    "Pods/hermes-engine/destroot/Library/Frameworks/macosx/hermes.framework/Versions/Current/hermes",
    "Pods/hermes-engine/destroot/Library/Frameworks/universal/hermes.xcframework/ios-arm64/hermes.framework/hermes",
    "Pods/hermes-engine/destroot/Library/Frameworks/universal/hermes.xcframework/ios-arm64_x86_64-maccatalyst/hermes.framework/hermes"
  ]

  framework_paths.each do |framework_relative_path|
    strip_bitcode_from_framework(bitcode_strip_path, framework_relative_path)
  end

  # Xcode 16: CocoaPods adds `-import-underlying-module` to every Swift pod's
  # xcconfig, even pure-Swift pods that have no underlying Objective-C module.
  # Under Xcode 16 this makes Swift look for a non-existent ObjC module and fails
  # the build (e.g. FirebaseRemoteConfigInterop, FirebaseSessions). Strip the flag
  # ONLY from pods with no ObjC sources; mixed pods (Crashlytics, VisionCamera,
  # Breez) genuinely need it, so they are left untouched.
  support_files_dir = File.join(Dir.pwd, 'Pods', 'Target Support Files')
  Dir.glob(File.join(support_files_dir, '*')).each do |pod_dir|
    pod_name = File.basename(pod_dir)
    pod_source = File.join(Dir.pwd, 'Pods', pod_name)
    next unless File.directory?(pod_source)
    next unless Dir.glob(File.join(pod_source, '**', '*.{m,mm}')).empty?
    Dir.glob(File.join(pod_dir, '*.xcconfig')).each do |xcconfig|
      contents = File.read(xcconfig)
      next unless contents.include?('-import-underlying-module')
      File.write(xcconfig, contents.gsub(' -import-underlying-module', ''))
      puts "Stripped -import-underlying-module from Swift-only pod #{pod_name}"
    end
  end

  # Belt-and-suspenders for the line above: force library evolution OFF directly
  # in every pod xcconfig, so no .swiftinterface is emitted/verified under Xcode 16.
  Dir.glob(File.join(support_files_dir, '*', '*.xcconfig')).each do |xcconfig|
    contents = File.read(xcconfig)
    next unless contents.include?('BUILD_LIBRARY_FOR_DISTRIBUTION = YES')
    File.write(xcconfig, contents.gsub('BUILD_LIBRARY_FOR_DISTRIBUTION = YES', 'BUILD_LIBRARY_FOR_DISTRIBUTION = NO'))
  end

  # Fix Xcode 26: swiftCompatibility56 and swiftCompatibilityPacks libraries were
  # removed from the toolchain. Pre-built Swift libraries (Firebase, BreezSDK) still
  # reference them. Mark these symbols as allowed-undefined since they are not needed
  # at runtime with Swift 6.2+.
  swift_compat_flags = ' -Wl,-U,__swift_FORCE_LOAD_$_swiftCompatibility56 -Wl,-U,__swift_FORCE_LOAD_$_swiftCompatibilityPacks'
  ['Pods-LNFlash', 'Pods-LNFlash-Alt'].each do |aggregate_name|
    agg_dir = File.join(support_files_dir, aggregate_name)
    next unless Dir.exist?(agg_dir)
    Dir.glob(File.join(agg_dir, '*.xcconfig')).each do |xcconfig|
      contents = File.read(xcconfig)
      next if contents.include?('swiftCompatibility56')
      if contents.match?(/^OTHER_LDFLAGS\s*=/)
        contents = contents.gsub(/^(OTHER_LDFLAGS\s*=.*)$/, "\\1#{swift_compat_flags}")
      else
        contents += "\nOTHER_LDFLAGS = $(inherited)#{swift_compat_flags}\n"
      end
      File.write(xcconfig, contents)
      puts "Added swiftCompatibility56 workaround to #{aggregate_name}/#{File.basename(xcconfig)}"
    end
  end

  # React Native 0.77 Yoga sources include nested private headers with
  # <yoga/...> paths, but the podspec only exposes top-level public headers.
  # Link those nested headers into CocoaPods' public header tree so clean
  # installs compile reliably under Xcode.
  yoga_source_dir = File.expand_path('../node_modules/react-native/ReactCommon/yoga/yoga', Dir.pwd)
  yoga_public_dir = File.join(Dir.pwd, 'Pods', 'Headers', 'Public', 'Yoga', 'yoga')
  if File.directory?(yoga_source_dir) && File.directory?(yoga_public_dir)
    Dir.glob(File.join(yoga_source_dir, '**', '*.h')).each do |header|
      relative_header = header.delete_prefix("#{yoga_source_dir}/")
      next unless relative_header.include?('/')

      public_header = File.join(yoga_public_dir, relative_header)
      FileUtils.mkdir_p(File.dirname(public_header))
      FileUtils.ln_sf(header, public_header)
    end
    puts "Linked nested Yoga headers for Xcode"
  end

  # use GoogleService-Info.dev.plist if GoogleService-Info.plist is not exits
  app_path = File.join(Dir.pwd, 'LNFlash') 
  google_service_plist = File.join(app_path, 'GoogleService-Info.plist')
  google_service_dev = File.join(app_path, 'GoogleService-Info.dev.plist')
  
  unless File.exist?(google_service_plist) && File.size?(google_service_plist)
    if File.exist?(google_service_dev)
      puts "⚠️ GoogleService-Info.plist not found. Using GoogleService-Info.dev.plist instead."
      FileUtils.cp(google_service_dev, google_service_plist)
    else
      puts "⚠️ Neither GoogleService-Info.plist nor GoogleService-Info.dev.plist found!"
    end
  end
  # end
end


