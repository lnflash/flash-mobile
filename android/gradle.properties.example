# Project-wide Gradle settings.
#
# build-check.yml builds Android debug from a straight copy of this file, as
# a proxy for android-deploy.yml's real release config. Every non-secret line
# below must also appear in that workflow's "Create gradle.properties"
# heredoc, or a green build-check stops proving the real deploy build works.

# Specifies the JVM arguments used for the daemon process.
org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=2g

# AndroidX package structure
android.useAndroidX=true

# React Native architectures to build
reactNativeArchitectures=armeabi-v7a,arm64-v8a,x86,x86_64

# Enable the new architecture (TurboModules / Fabric)
newArchEnabled=true

# Enable Hermes JS engine
hermesEnabled=true

android.aapt2Version=8.6.1-11315950

# Override galoymoney react-native-geetest-module SDK versions
GeetestModule_compileSdkVersion=android-31
GeetestModule_targetSdkVersion=31
GeetestModule_minSdkVersion=26
GeetestModule_buildToolsVersion=31.0.0

# Release signing config (fill in your values)
MYAPP_UPLOAD_STORE_FILE=release-keystore.jks
MYAPP_UPLOAD_KEY_ALIAS=flash-release
MYAPP_UPLOAD_STORE_PASSWORD=your_store_password
MYAPP_UPLOAD_KEY_PASSWORD=your_key_password
