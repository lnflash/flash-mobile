platform :ios do
  desc "Setup code signing for CI"
  lane :setup_signing do
    app_identifiers = [
      "com.lnflash",
      "com.lnflash.FlashWidget",
      "com.lnflash.watchkitapp",
      "com.lnflash.watchkitapp.FlashWatchComplication"
    ]

    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: ENV["MATCH_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      match(
        type: "appstore",
        app_identifier: app_identifiers,
        keychain_name: "ci_keychain",
        keychain_password: ENV["MATCH_PASSWORD"],
        readonly: true
      )
    else
      match(type: "appstore", app_identifier: app_identifiers, readonly: true)
    end
  end

  desc "Deploy to TestFlight (beta)"
  lane :beta do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing

    update_ios_version_from_tag("ios", ["LNFlash", "FlashWidgetExtension", "FlashWatch Watch App", "FlashWatchComplicationExtension"])

    # LNFlash embeds FlashWidgetExtension + "FlashWatch Watch App" (which
    # itself embeds FlashWatchComplicationExtension) into the same .ipa —
    # App Store Connect processing rejects a container/embedded
    # CFBundleVersion mismatch, so every real target must move together.
    ios_build_number = latest_testflight_build_number(api_key: api_key) + 1
    ["LNFlash", "FlashWidgetExtension", "FlashWatch Watch App", "FlashWatchComplicationExtension"].each do |target_name|
      set_current_project_version("ios/LNFlash.xcodeproj", target_name, ios_build_number)
    end

    # deployment: true fails loudly if Podfile/Podfile.lock ever disagree,
    # instead of silently re-resolving an unreviewed pod graph mid-release.
    cocoapods(podfile: "ios/Podfile", clean_install: true, deployment: true)

    profile_main = ENV["sigh_com.lnflash_appstore_profile-name"] || "match AppStore com.lnflash"
    profile_widget = ENV["sigh_com.lnflash.FlashWidget_appstore_profile-name"] || "match AppStore com.lnflash.FlashWidget"
    profile_watch = ENV["sigh_com.lnflash.watchkitapp_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp"
    profile_complication = ENV["sigh_com.lnflash.watchkitapp.FlashWatchComplication_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp.FlashWatchComplication"

    signing_targets = {
      "LNFlash" => profile_main,
      "FlashWidgetExtension" => profile_widget,
      "FlashWatch Watch App" => profile_watch,
      "FlashWatchComplicationExtension" => profile_complication
    }
    signing_targets.each do |target_name, profile|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "ios/LNFlash.xcodeproj",
        targets: [target_name],
        # Release only — Debug's build settings must not be touched, since
        # this same project.pbxproj gets committed back to main by the
        # version-bump step below.
        build_configurations: ["Release"],
        profile_name: profile,
        code_sign_identity: "Apple Distribution",
        # Developer Portal team ID (per Appfile's team_id), NOT the App Store
        # Connect / itc_team_id (H7UAM79QQP) — this account has distinct IDs
        # for the two roles, and update_code_signing_settings' team_id: sets
        # the project's DEVELOPMENT_TEAM, which Xcode resolves against the
        # Developer Portal.
        team_id: ENV["TEAM_ID"] || "27HU729V9P"
      )
    end

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Flash.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.lnflash" => profile_main,
          "com.lnflash.FlashWidget" => profile_widget,
          "com.lnflash.watchkitapp" => profile_watch,
          "com.lnflash.watchkitapp.FlashWatchComplication" => profile_complication
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/Flash.ipa",
      skip_waiting_for_build_processing: true
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash")
    build = current_project_version_for("ios/LNFlash.xcodeproj", "LNFlash")

    commit_and_tag_after_upload!(
      paths: ["ios/LNFlash.xcodeproj/project.pbxproj", "ios/LNFlash/Info.plist"],
      message: "chore(ios): bump version to #{version} (#{build}) [skip ci]",
      tag: "ios/v#{version}-#{build}"
    )
  end

  desc "Deploy to App Store (release)"
  lane :release do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing

    update_ios_version_from_tag("ios", ["LNFlash", "FlashWidgetExtension", "FlashWatch Watch App", "FlashWatchComplicationExtension"])

    # LNFlash embeds FlashWidgetExtension + "FlashWatch Watch App" (which
    # itself embeds FlashWatchComplicationExtension) into the same .ipa —
    # App Store Connect processing rejects a container/embedded
    # CFBundleVersion mismatch, so every real target must move together.
    ios_build_number = latest_testflight_build_number(api_key: api_key) + 1
    ["LNFlash", "FlashWidgetExtension", "FlashWatch Watch App", "FlashWatchComplicationExtension"].each do |target_name|
      set_current_project_version("ios/LNFlash.xcodeproj", target_name, ios_build_number)
    end

    # deployment: true fails loudly if Podfile/Podfile.lock ever disagree,
    # instead of silently re-resolving an unreviewed pod graph mid-release.
    cocoapods(podfile: "ios/Podfile", clean_install: true, deployment: true)

    profile_main = ENV["sigh_com.lnflash_appstore_profile-name"] || "match AppStore com.lnflash"
    profile_widget = ENV["sigh_com.lnflash.FlashWidget_appstore_profile-name"] || "match AppStore com.lnflash.FlashWidget"
    profile_watch = ENV["sigh_com.lnflash.watchkitapp_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp"
    profile_complication = ENV["sigh_com.lnflash.watchkitapp.FlashWatchComplication_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp.FlashWatchComplication"

    signing_targets = {
      "LNFlash" => profile_main,
      "FlashWidgetExtension" => profile_widget,
      "FlashWatch Watch App" => profile_watch,
      "FlashWatchComplicationExtension" => profile_complication
    }
    signing_targets.each do |target_name, profile|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "ios/LNFlash.xcodeproj",
        targets: [target_name],
        # Release only — Debug's build settings must not be touched, since
        # this same project.pbxproj gets committed back to main by the
        # version-bump step below.
        build_configurations: ["Release"],
        profile_name: profile,
        code_sign_identity: "Apple Distribution",
        # Developer Portal team ID (per Appfile's team_id), NOT the App Store
        # Connect / itc_team_id (H7UAM79QQP) — this account has distinct IDs
        # for the two roles, and update_code_signing_settings' team_id: sets
        # the project's DEVELOPMENT_TEAM, which Xcode resolves against the
        # Developer Portal.
        team_id: ENV["TEAM_ID"] || "27HU729V9P"
      )
    end

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Flash.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.lnflash" => profile_main,
          "com.lnflash.FlashWidget" => profile_widget,
          "com.lnflash.watchkitapp" => profile_watch,
          "com.lnflash.watchkitapp.FlashWatchComplication" => profile_complication
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/Flash.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash")
    build = current_project_version_for("ios/LNFlash.xcodeproj", "LNFlash")

    commit_and_tag_after_upload!(
      paths: ["ios/LNFlash.xcodeproj/project.pbxproj", "ios/LNFlash/Info.plist"],
      message: "chore(ios): release version #{version} (#{build}) [skip ci]",
      tag: "ios/release/v#{version}-#{build}",
      force: true
    )
  end

  # ---------------------------------------------------------------------------
  # LNFlash-Alt
  # ---------------------------------------------------------------------------

  desc "Setup code signing for CI (Alt)"
  lane :setup_signing_alt do
    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: ENV["MATCH_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      match(
        type: "appstore",
        app_identifier: "com.flashapp.alt",
        keychain_name: "ci_keychain",
        keychain_password: ENV["MATCH_PASSWORD"],
        readonly: true
      )
    else
      match(type: "appstore", app_identifier: "com.flashapp.alt", readonly: true)
    end
  end

  desc "Deploy Alt to TestFlight (beta)"
  lane :beta_alt do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing_alt

    update_ios_version_from_tag("ios-alt", ["LNFlash-Alt"])

    set_current_project_version(
      "ios/LNFlash.xcodeproj",
      "LNFlash-Alt",
      latest_testflight_build_number(api_key: api_key, app_identifier: "com.flashapp.alt") + 1
    )

    # deployment: true fails loudly if Podfile/Podfile.lock ever disagree,
    # instead of silently re-resolving an unreviewed pod graph mid-release.
    cocoapods(podfile: "ios/Podfile", clean_install: true, deployment: true)

    profile_name = ENV["sigh_com.flashapp.alt_appstore_profile-name"] || "match AppStore com.flashapp.alt"

    # Unlike build_app's xcargs below (which only override signing for the
    # export/archive step), this makes the project's own DEVELOPMENT_TEAM
    # agree with the team match() actually fetched com.flashapp.alt's
    # certificate/profile for — a disagreement here is a documented xcodebuild
    # signing-resolution failure class. Mirrors the main app's fix.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/LNFlash.xcodeproj",
      targets: ["LNFlash-Alt"],
      build_configurations: ["Release"],
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution",
      team_id: ENV["TEAM_ID"] || "27HU729V9P"
    )

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash-Alt",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlashAlt.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.flashapp.alt" => profile_name
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.flashapp.alt",
      ipa: "./build/FlashAlt.ipa",
      skip_waiting_for_build_processing: true
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash-Alt")
    build = current_project_version_for("ios/LNFlash.xcodeproj", "LNFlash-Alt")

    commit_and_tag_after_upload!(
      paths: ["ios/LNFlash.xcodeproj/project.pbxproj"],
      message: "chore(ios-alt): bump version to #{version} (#{build}) [skip ci]",
      tag: "ios-alt/v#{version}-#{build}"
    )
  end

  desc "Deploy Alt to App Store (release)"
  lane :release_alt do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing_alt

    update_ios_version_from_tag("ios-alt", ["LNFlash-Alt"])

    set_current_project_version(
      "ios/LNFlash.xcodeproj",
      "LNFlash-Alt",
      latest_testflight_build_number(api_key: api_key, app_identifier: "com.flashapp.alt") + 1
    )

    # deployment: true fails loudly if Podfile/Podfile.lock ever disagree,
    # instead of silently re-resolving an unreviewed pod graph mid-release.
    cocoapods(podfile: "ios/Podfile", clean_install: true, deployment: true)

    profile_name = ENV["sigh_com.flashapp.alt_appstore_profile-name"] || "match AppStore com.flashapp.alt"

    # Unlike build_app's xcargs below (which only override signing for the
    # export/archive step), this makes the project's own DEVELOPMENT_TEAM
    # agree with the team match() actually fetched com.flashapp.alt's
    # certificate/profile for — a disagreement here is a documented xcodebuild
    # signing-resolution failure class. Mirrors the main app's fix.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/LNFlash.xcodeproj",
      targets: ["LNFlash-Alt"],
      build_configurations: ["Release"],
      profile_name: profile_name,
      code_sign_identity: "Apple Distribution",
      team_id: ENV["TEAM_ID"] || "27HU729V9P"
    )

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash-Alt",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlashAlt.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.flashapp.alt" => profile_name
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.flashapp.alt",
      ipa: "./build/FlashAlt.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash-Alt")
    build = current_project_version_for("ios/LNFlash.xcodeproj", "LNFlash-Alt")

    commit_and_tag_after_upload!(
      paths: ["ios/LNFlash.xcodeproj/project.pbxproj"],
      message: "chore(ios-alt): release version #{version} (#{build}) [skip ci]",
      tag: "ios-alt/release/v#{version}-#{build}",
      force: true
    )
  end
end

# ---------------------------------------------------------------------------
# Android
# ---------------------------------------------------------------------------

platform :android do
  desc "Deploy to Google Play Internal Testing (beta)"
  lane :beta do
    ensure_git_status_clean unless ENV['CI']

    update_android_version_from_tag
    version_code = increment_android_version_code

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      flags: "--no-daemon --stacktrace"
    )

    # Store listing (description, images, changelogs) is managed manually via
    # Play Console, not from fastlane/metadata/android/en-US/ — that scaffold
    # exists for a possible future automation pass but nothing in this Fastfile
    # reads it today. Same on all three upload_to_play_store calls below.
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )

    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    version_name = content.match(/versionName\s+"([^"]+)"/)[1]

    commit_and_tag_after_upload!(
      paths: ["android/app/build.gradle"],
      message: "chore(android): bump version to #{version_name} (#{version_code}) [skip ci]",
      tag: "android/v#{version_name}-#{version_code}"
    )
  end

  desc "Deploy to Google Play Production (release)"
  lane :release do
    ensure_git_status_clean unless ENV['CI']

    update_android_version_from_tag
    version_code = increment_android_version_code

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      flags: "--no-daemon --stacktrace"
    )

    upload_to_play_store(
      track: "production",
      rollout: "0.1",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )

    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    version_name = content.match(/versionName\s+"([^"]+)"/)[1]

    commit_and_tag_after_upload!(
      paths: ["android/app/build.gradle"],
      message: "chore(android): release version #{version_name} (#{version_code}) [skip ci]",
      tag: "android/release/v#{version_name}-#{version_code}",
      force: true
    )
  end

  desc "Promote Internal Testing to Beta"
  lane :promote_to_beta do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "beta",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
