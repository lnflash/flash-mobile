opt_out_usage

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def version_from_git_tag(platform)
  # Platform-prefixed tags only (ios/v1.2.3, ios-alt/v1.2.3, android/v1.2.3)
  # — deliberately no generic "v*" fallback (removed: it could resolve a
  # long-stale, unrelated legacy tag whenever HEAD has no reachable
  # platform tag yet, which refuse_version_regression! below would then
  # treat as a real regression and hard-fail on — exactly on this
  # pipeline's own first activation. Returning empty is safe: both callers'
  # `unless version.empty?` guard already leaves the committed version
  # untouched rather than writing anything wrong.)
  tag = `git describe --tags --match '#{platform}/v*' --abbrev=0 2>/dev/null`.strip
  raw = tag.gsub(%r{^(ios-alt|ios|android)/}, "").gsub(/^v/, "")
  # Every successful beta/release run tags itself as "<prefix>/v#{version}-#{build}"
  # (see add_git_tag below), so the NEXT invocation's `git describe --abbrev=0`
  # — whenever HEAD isn't a fresh, exactly-tagged commit (e.g. a workflow_dispatch
  # with no new tag) — resolves to that already-dashed tag, not a clean "x.y.z".
  # Extract just the leading semver so we never feed "0.6.1-45" (or worse, a
  # git-describe-appended "-N-gSHA" on top of that) into increment_version_number.
  candidate = raw[/\A\d+\.\d+\.\d+/] || raw
  return "" if candidate.empty?
  # A tag matching the trigger glob (e.g. "ios/v-hotfix", "android/v.1.2")
  # doesn't guarantee the remainder is a real version — refuse_version_regression!
  # feeds this straight into Gem::Version.new, which raises a raw ArgumentError
  # on anything else. Fail loudly and clearly here instead, before that lane
  # ever touches signing/build/upload.
  unless candidate.match?(/\A\d+(\.\d+){0,2}\z/)
    UI.user_error!("Tag '#{tag}' does not resolve to a valid version (got '#{candidate}') — expected '#{platform}/vX.Y.Z[-build]'. Fix or delete the tag and re-push.")
  end
  candidate
end

# Every lane's post-upload git_commit + add_git_tag was previously unguarded:
# if either raised (a transient git error, a tag collision against something
# pushed out-of-band, a runner timeout), the lane exited non-zero with no
# indication the store upload immediately before it had already succeeded —
# and the GitHub Actions "Push version bump" step, the ONLY place carrying
# that warning, is skipped outright by its own `if: success()` guard when
# the lane itself already failed. Centralizing this ensures the warning
# fires regardless of which of the two calls breaks, before the job goes
# red for what looks like an ordinary CI failure.
def commit_and_tag_after_upload!(paths:, message:, tag:, force: false)
  return unless is_ci
  begin
    git_commit(path: paths, message: message, allow_nothing_to_commit: true)
    add_git_tag(tag: tag, force: force)
  rescue => e
    UI.error(
      "Post-upload git bookkeeping failed (#{e.message}) — the store upload above ALREADY SUCCEEDED. " \
      "Do NOT use GitHub's 'Re-run failed jobs' or re-dispatch this workflow; that would trigger a SECOND " \
      "real upload. Recover manually: fetch origin/main, recreate this commit yourself " \
      "(message: \"#{message}\"), and push it — no --follow-tags, no separate tag push (see the workflow " \
      "YAML's own 'Push version bump' step for why)."
    )
    raise
  end
end

# version_from_git_tag resolves the NEAREST reachable tag by commit-graph
# distance (git describe), not the highest semver, and is independent of
# whatever version is already committed in the project files. A beta run
# with no new tag pinned (workflow_dispatch with a blank ref — explicitly
# sanctioned for beta/promote_to_beta by these workflows' own ref input
# description) resolves to whatever the last real tag was, which can be
# OLDER than a version a previous run already committed to main. Refusing
# to move backwards here is the only thing standing between that and a
# silently regressed version string shipping to a real store listing —
# versionCode/build-number still increment correctly and independently
# (they're sourced from Play/App Store Connect, not from this comparison),
# so nothing else in this pipeline would catch it.
def refuse_version_regression!(current, candidate, what)
  return unless current
  if Gem::Version.new(candidate) < Gem::Version.new(current)
    UI.user_error!(
      "Refusing to regress #{what} from #{current} to #{candidate} (resolved from the nearest matching " \
      "git tag). This usually means this lane ran with no new tag pinned while a newer version was " \
      "already committed to main by a previous run. Push a new tag for the intended version, or pin ref " \
      "explicitly to the tag you actually want."
    )
  end
end

def update_ios_version_from_tag(tag_prefix, target_names)
  version = version_from_git_tag(tag_prefix)
  unless version.empty?
    target_names.each do |target_name|
      current = current_marketing_version_for("ios/LNFlash.xcodeproj", target_name)
      refuse_version_regression!(current, version, "#{target_name}'s MARKETING_VERSION")
      set_marketing_version("ios/LNFlash.xcodeproj", target_name, version)
    end
    UI.message("iOS version set to #{version} for #{target_names.join(', ')}")
  end
end

def update_android_version_from_tag
  version = version_from_git_tag("android")
  unless version.empty?
    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    current = content.match(/versionName\s+"([^"]+)"/)[1]

    # refuse_version_regression! alone only catches a regression relative to
    # the locally checked-out build.gradle. Play enforces no ordering on
    # versionName at all (unlike versionCode, which it hard-rejects if
    # reused/lower) — if a previous run's real upload succeeded but its
    # version-bump commit never made it back to main (the "Push version
    # bump" step exhausted its retries), local state can still show the OLD
    # version while Play's track already has a NEWER one live, and nothing
    # else in this pipeline would catch that. Fold in Play's actual release
    # names from both tracks, mirroring increment_android_version_code's own
    # live-versionCode cross-check below (same graceful-degrade-on-
    # query-failure pattern). Filters to plain dot-numeric strings only —
    # Play release names are free-form and can be hand-edited in Play
    # Console to something Gem::Version can't parse.
    live_names = []
    begin
      require "supply/reader"
      ["internal", "production"].each do |track|
        google_play_track_version_codes(track: track) # also populates Supply.config for the read below
        live_names += Supply::Reader.new.track_release_names
      end
      live_names = live_names.select { |v| v =~ /\A\d+(\.\d+)*\z/ }
    rescue => e
      UI.important(
        "Could not query Play Console for existing release names (#{e.message}) " \
        "— falling back to local git/file state only. Expected on the very first " \
        "release, before either track has a build; investigate otherwise."
      )
    end
    baseline = ([current] + live_names).compact.max_by { |v| Gem::Version.new(v) }
    refuse_version_regression!(baseline, version, "Android versionName")

    content = content.gsub(/versionName\s+"[^"]+"/, "versionName \"#{version}\"")
    File.write(gradle_path, content)
    UI.message("Android versionName set to #{version}")
  end
end

def increment_android_version_code
  gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
  content = File.read(gradle_path)
  local_code = content.match(/versionCode\s+(\d+)/)[1].to_i

  # The checked-out ref can be older than main's tip (workflow_dispatch's ref
  # input exists precisely so a release can pin an exact beta-tested commit),
  # so the locally-committed versionCode can lag what a later beta already
  # pushed to Play. Query the real ceiling across both tracks Play rejects
  # any reused versionCode outright, so trusting local state alone risks a
  # collision on exactly the release-promotion flow this pipeline exists for.
  live_codes = []
  begin
    live_codes = google_play_track_version_codes(track: "internal") +
                 google_play_track_version_codes(track: "production")
  rescue => e
    UI.important(
      "Could not query Play Console for existing version codes (#{e.message}) " \
      "— falling back to the locally committed versionCode. Expected on the " \
      "very first release, before either track has a build; investigate otherwise."
    )
  end

  current_code = [local_code, *live_codes].max
  new_code = current_code + 1
  content = content.gsub(/versionCode\s+\d+/, "versionCode #{new_code}")
  File.write(gradle_path, content)
  UI.message("Android versionCode incremented: #{current_code} → #{new_code} (local: #{local_code}, live max: #{live_codes.max || "n/a"})")
  new_code
end

# increment_build_number / get_build_number are agvtool-based and have no
# concept of "target" at all (confirmed against the pinned fastlane 2.237.0
# action source — :target is not a valid option and agvtool itself has no
# per-target scoping mechanism), so they can't be used to bump one target's
# build number without touching every target sharing this xcodeproj. These
# two helpers do the same job the update_code_signing_settings action already
# does internally: read/write the target's own build settings directly via
# the xcodeproj gem (an existing fastlane dependency — no new gem needed).
# xcodeproj_path is always passed as a project-root-relative string (e.g.
# "ios/LNFlash.xcodeproj"), but these are plain Ruby methods, not registered
# fastlane Actions — fastlane's Runner#execute chdirs the ENTIRE lane body
# into the fastlane/ folder (runner.rb) and only chdirs back out to the
# project root inside Runner#execute_action's own wrapper, which wraps real
# Actions only. A bare method call like this never gets that treatment, so
# resolving xcodeproj_path directly against Dir.pwd looks for
# fastlane/ios/LNFlash.xcodeproj and crashes. __dir__ anchors to the
# Fastfile's own location on disk regardless of the caller's CWD — confirmed
# via the real fastlane 2.237.0 CLI (not just this comment): the naive
# version crashes with "Unable to open .../fastlane/ios/LNFlash.xcodeproj",
# this version doesn't.
def resolve_xcodeproj_path(xcodeproj_path)
  File.expand_path(File.join(__dir__, "..", xcodeproj_path))
end

def set_current_project_version(xcodeproj_path, target_name, build_number)
  require "xcodeproj"
  project = Xcodeproj::Project.open(resolve_xcodeproj_path(xcodeproj_path))
  target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Target '#{target_name}' not found in #{xcodeproj_path}") unless target
  target.build_configurations.each do |config|
    config.build_settings["CURRENT_PROJECT_VERSION"] = build_number.to_s
  end
  project.save
  build_number.to_s
end

def current_project_version_for(xcodeproj_path, target_name)
  require "xcodeproj"
  project = Xcodeproj::Project.open(resolve_xcodeproj_path(xcodeproj_path))
  target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Target '#{target_name}' not found in #{xcodeproj_path}") unless target
  config = target.build_configurations.find { |c| c.name == "Release" } || target.build_configurations.first
  config.build_settings["CURRENT_PROJECT_VERSION"]
end

def current_marketing_version_for(xcodeproj_path, target_name)
  require "xcodeproj"
  project = Xcodeproj::Project.open(resolve_xcodeproj_path(xcodeproj_path))
  target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Target '#{target_name}' not found in #{xcodeproj_path}") unless target
  config = target.build_configurations.find { |c| c.name == "Release" } || target.build_configurations.first
  config.build_settings["MARKETING_VERSION"]
end

# increment_version_number has the identical agvtool per-target gap as
# increment_build_number above: its available_options is only
# [:bump_type, :version_number, :version_appendix, :xcodeproj] in the pinned
# fastlane 2.237.0 source, and its underlying XcodeprojHelper writes
# MARKETING_VERSION to every target in the project. Scoped the same way.
def set_marketing_version(xcodeproj_path, target_name, version)
  require "xcodeproj"
  project = Xcodeproj::Project.open(resolve_xcodeproj_path(xcodeproj_path))
  target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Target '#{target_name}' not found in #{xcodeproj_path}") unless target
  target.build_configurations.each do |config|
    config.build_settings["MARKETING_VERSION"] = version.to_s
  end
  project.save
  version.to_s
end

