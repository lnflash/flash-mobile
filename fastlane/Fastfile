opt_out_usage

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def version_from_git_tag(platform)
  # Try platform-specific tag first (ios/v1.2.3, ios-alt/v1.2.3, android/v1.2.3), then generic v1.2.3
  tag = `git describe --tags --match '#{platform}/v*' --abbrev=0 2>/dev/null`.strip
  if tag.empty?
    tag = `git describe --tags --match 'v*' --abbrev=0 2>/dev/null`.strip
  end
  raw = tag.gsub(%r{^(ios-alt|ios|android)/}, "").gsub(/^v/, "")
  # Every successful beta/release run tags itself as "<prefix>/v#{version}-#{build}"
  # (see add_git_tag below), so the NEXT invocation's `git describe --abbrev=0`
  # — whenever HEAD isn't a fresh, exactly-tagged commit (e.g. a workflow_dispatch
  # with no new tag) — resolves to that already-dashed tag, not a clean "x.y.z".
  # Extract just the leading semver so we never feed "0.6.1-45" (or worse, a
  # git-describe-appended "-N-gSHA" on top of that) into increment_version_number.
  raw[/\A\d+\.\d+\.\d+/] || raw
end

def update_ios_version_from_tag(tag_prefix = "ios")
  version = version_from_git_tag(tag_prefix)
  unless version.empty?
    increment_version_number(
      version_number: version,
      xcodeproj: "ios/LNFlash.xcodeproj"
    )
    UI.message("iOS version set to #{version}")
  end
end

def update_android_version_from_tag
  version = version_from_git_tag("android")
  unless version.empty?
    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    content = content.gsub(/versionName\s+"[^"]+"/, "versionName \"#{version}\"")
    File.write(gradle_path, content)
    UI.message("Android versionName set to #{version}")
  end
end

def increment_android_version_code
  gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
  content = File.read(gradle_path)
  current_code = content.match(/versionCode\s+(\d+)/)[1].to_i
  new_code = current_code + 1
  content = content.gsub(/versionCode\s+\d+/, "versionCode #{new_code}")
  File.write(gradle_path, content)
  UI.message("Android versionCode incremented: #{current_code} → #{new_code}")
  new_code
end

# ---------------------------------------------------------------------------
# iOS
# ---------------------------------------------------------------------------

platform :ios do
  desc "Setup code signing for CI"
  lane :setup_signing do
    app_identifiers = [
      "com.lnflash",
      "com.lnflash.FlashWidget",
      "com.lnflash.watchkitapp",
      "com.lnflash.watchkitapp.FlashWatchComplication"
    ]

    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: ENV["MATCH_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      match(
        type: "appstore",
        app_identifier: app_identifiers,
        keychain_name: "ci_keychain",
        keychain_password: ENV["MATCH_PASSWORD"],
        readonly: true
      )
    else
      match(type: "appstore", app_identifier: app_identifiers, readonly: true)
    end
  end

  desc "Deploy to TestFlight (beta)"
  lane :beta do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing

    update_ios_version_from_tag

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
      xcodeproj: "ios/LNFlash.xcodeproj",
      # Scoped: this xcodeproj also holds the Alt app's target, and an
      # unscoped call bumps CURRENT_PROJECT_VERSION for every target in the
      # project — stomping the other app's build-number setting on every run.
      target: "LNFlash"
    )

    cocoapods(podfile: "ios/Podfile", clean_install: true)

    profile_main = ENV["sigh_com.lnflash_appstore_profile-name"] || "match AppStore com.lnflash"
    profile_widget = ENV["sigh_com.lnflash.FlashWidget_appstore_profile-name"] || "match AppStore com.lnflash.FlashWidget"
    profile_watch = ENV["sigh_com.lnflash.watchkitapp_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp"
    profile_complication = ENV["sigh_com.lnflash.watchkitapp.FlashWatchComplication_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp.FlashWatchComplication"

    signing_targets = {
      "LNFlash" => profile_main,
      "FlashWidgetExtension" => profile_widget,
      "FlashWatch Watch App" => profile_watch,
      "FlashWatchComplicationExtension" => profile_complication
    }
    signing_targets.each do |target_name, profile|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "ios/LNFlash.xcodeproj",
        targets: [target_name],
        # Release only — Debug's build settings must not be touched, since
        # this same project.pbxproj gets committed back to main by the
        # version-bump step below.
        build_configuration: "Release",
        profile_name: profile,
        code_sign_identity: "Apple Distribution",
        # Developer Portal team ID (per Appfile's team_id), NOT the App Store
        # Connect / itc_team_id (H7UAM79QQP) — this account has distinct IDs
        # for the two roles, and update_code_signing_settings' team_id: sets
        # the project's DEVELOPMENT_TEAM, which Xcode resolves against the
        # Developer Portal.
        team_id: ENV["TEAM_ID"] || "27HU729V9P"
      )
    end

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Flash.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.lnflash" => profile_main,
          "com.lnflash.FlashWidget" => profile_widget,
          "com.lnflash.watchkitapp" => profile_watch,
          "com.lnflash.watchkitapp.FlashWatchComplication" => profile_complication
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/Flash.ipa",
      skip_waiting_for_build_processing: true
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash")
    build = get_build_number(xcodeproj: "ios/LNFlash.xcodeproj")

    if is_ci
      git_commit(
        path: ["ios/LNFlash.xcodeproj/project.pbxproj", "ios/LNFlash/Info.plist"],
        message: "chore(ios): bump version to #{version} (#{build}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "ios/v#{version}-#{build}")
    end
  end

  desc "Deploy to App Store (release)"
  lane :release do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing

    update_ios_version_from_tag

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
      xcodeproj: "ios/LNFlash.xcodeproj",
      # Scoped: this xcodeproj also holds the Alt app's target, and an
      # unscoped call bumps CURRENT_PROJECT_VERSION for every target in the
      # project — stomping the other app's build-number setting on every run.
      target: "LNFlash"
    )

    cocoapods(podfile: "ios/Podfile", clean_install: true)

    profile_main = ENV["sigh_com.lnflash_appstore_profile-name"] || "match AppStore com.lnflash"
    profile_widget = ENV["sigh_com.lnflash.FlashWidget_appstore_profile-name"] || "match AppStore com.lnflash.FlashWidget"
    profile_watch = ENV["sigh_com.lnflash.watchkitapp_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp"
    profile_complication = ENV["sigh_com.lnflash.watchkitapp.FlashWatchComplication_appstore_profile-name"] || "match AppStore com.lnflash.watchkitapp.FlashWatchComplication"

    signing_targets = {
      "LNFlash" => profile_main,
      "FlashWidgetExtension" => profile_widget,
      "FlashWatch Watch App" => profile_watch,
      "FlashWatchComplicationExtension" => profile_complication
    }
    signing_targets.each do |target_name, profile|
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "ios/LNFlash.xcodeproj",
        targets: [target_name],
        # Release only — Debug's build settings must not be touched, since
        # this same project.pbxproj gets committed back to main by the
        # version-bump step below.
        build_configuration: "Release",
        profile_name: profile,
        code_sign_identity: "Apple Distribution",
        # Developer Portal team ID (per Appfile's team_id), NOT the App Store
        # Connect / itc_team_id (H7UAM79QQP) — this account has distinct IDs
        # for the two roles, and update_code_signing_settings' team_id: sets
        # the project's DEVELOPMENT_TEAM, which Xcode resolves against the
        # Developer Portal.
        team_id: ENV["TEAM_ID"] || "27HU729V9P"
      )
    end

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Flash.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.lnflash" => profile_main,
          "com.lnflash.FlashWidget" => profile_widget,
          "com.lnflash.watchkitapp" => profile_watch,
          "com.lnflash.watchkitapp.FlashWatchComplication" => profile_complication
        }
      },
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/Flash.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash")
    build = get_build_number(xcodeproj: "ios/LNFlash.xcodeproj")

    if is_ci
      git_commit(
        path: ["ios/LNFlash.xcodeproj/project.pbxproj", "ios/LNFlash/Info.plist"],
        message: "chore(ios): release version #{version} (#{build}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "ios/release/v#{version}-#{build}", force: true)
    end
  end

  # ---------------------------------------------------------------------------
  # LNFlash-Alt
  # ---------------------------------------------------------------------------

  desc "Setup code signing for CI (Alt)"
  lane :setup_signing_alt do
    if is_ci
      create_keychain(
        name: "ci_keychain",
        password: ENV["MATCH_PASSWORD"],
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )
      match(
        type: "appstore",
        app_identifier: "com.flashapp.alt",
        keychain_name: "ci_keychain",
        keychain_password: ENV["MATCH_PASSWORD"],
        readonly: true
      )
    else
      match(type: "appstore", app_identifier: "com.flashapp.alt", readonly: true)
    end
  end

  desc "Deploy Alt to TestFlight (beta)"
  lane :beta_alt do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing_alt

    update_ios_version_from_tag("ios-alt")

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key, app_identifier: "com.flashapp.alt") + 1,
      xcodeproj: "ios/LNFlash.xcodeproj",
      # Scoped: see the main app's lane for why this must not be project-wide.
      target: "LNFlash-Alt"
    )

    cocoapods(podfile: "ios/Podfile", clean_install: true)

    profile_name = ENV["sigh_com.flashapp.alt_appstore_profile-name"] || "match AppStore com.flashapp.alt"

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash-Alt",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlashAlt.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.flashapp.alt" => profile_name
        }
      },
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='#{profile_name}' ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.flashapp.alt",
      ipa: "./build/FlashAlt.ipa",
      skip_waiting_for_build_processing: true
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash-Alt")
    build = get_build_number(xcodeproj: "ios/LNFlash.xcodeproj")

    if is_ci
      git_commit(
        path: ["ios/LNFlash.xcodeproj/project.pbxproj"],
        message: "chore(ios-alt): bump version to #{version} (#{build}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "ios-alt/v#{version}-#{build}")
    end
  end

  desc "Deploy Alt to App Store (release)"
  lane :release_alt do
    ensure_git_status_clean unless ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )

    setup_signing_alt

    update_ios_version_from_tag("ios-alt")

    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key, app_identifier: "com.flashapp.alt") + 1,
      xcodeproj: "ios/LNFlash.xcodeproj",
      # Scoped: see the main app's lane for why this must not be project-wide.
      target: "LNFlash-Alt"
    )

    cocoapods(podfile: "ios/Podfile", clean_install: true)

    profile_name = ENV["sigh_com.flashapp.alt_appstore_profile-name"] || "match AppStore com.flashapp.alt"

    build_app(
      workspace: "ios/LNFlash.xcworkspace",
      scheme: "LNFlash-Alt",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FlashAlt.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.flashapp.alt" => profile_name
        }
      },
      xcargs: "CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='#{profile_name}' ENABLE_USER_SCRIPT_SANDBOXING=NO"
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.flashapp.alt",
      ipa: "./build/FlashAlt.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false
    )

    version = get_version_number(xcodeproj: "ios/LNFlash.xcodeproj", target: "LNFlash-Alt")
    build = get_build_number(xcodeproj: "ios/LNFlash.xcodeproj")

    if is_ci
      git_commit(
        path: ["ios/LNFlash.xcodeproj/project.pbxproj"],
        message: "chore(ios-alt): release version #{version} (#{build}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "ios-alt/release/v#{version}-#{build}", force: true)
    end
  end
end

# ---------------------------------------------------------------------------
# Android
# ---------------------------------------------------------------------------

platform :android do
  desc "Deploy to Google Play Internal Testing (beta)"
  lane :beta do
    ensure_git_status_clean unless ENV['CI']

    update_android_version_from_tag
    version_code = increment_android_version_code

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      flags: "--no-daemon --stacktrace"
    )

    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )

    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    version_name = content.match(/versionName\s+"([^"]+)"/)[1]

    if is_ci
      git_commit(
        path: ["android/app/build.gradle"],
        message: "chore(android): bump version to #{version_name} (#{version_code}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "android/v#{version_name}-#{version_code}")
    end
  end

  desc "Deploy to Google Play Production (release)"
  lane :release do
    ensure_git_status_clean unless ENV['CI']

    update_android_version_from_tag
    version_code = increment_android_version_code

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android",
      flags: "--no-daemon --stacktrace"
    )

    upload_to_play_store(
      track: "production",
      rollout: "0.1",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )

    gradle_path = File.join(Dir.pwd, "..", "android", "app", "build.gradle")
    content = File.read(gradle_path)
    version_name = content.match(/versionName\s+"([^"]+)"/)[1]

    if is_ci
      git_commit(
        path: ["android/app/build.gradle"],
        message: "chore(android): release version #{version_name} (#{version_code}) [skip ci]",
        allow_nothing_to_commit: true
      )
      add_git_tag(tag: "android/release/v#{version_name}-#{version_code}", force: true)
    end
  end

  desc "Promote Internal Testing to Beta"
  lane :promote_to_beta do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "beta",
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: true
    )
  end
end
