ITC_TEAM_ID=H7UAM79QQP
TEAM_ID=27HU729V9P
APP_IDENTIFIER=com.lnflash

# Android - Google Play
GOOGLE_PLAY_JSON_KEY_PATH=./google-play-key.json

# Android - Signing
